{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 03 · Inference Demo — End-to-End AGB Prediction\n",
    "\n",
    "Load a trained checkpoint, run inference on a single chip, and visualise the results.\n",
    "\n",
    "**Requirements**: A trained checkpoint (e.g., `results/utae/checkpoints/last.ckpt`)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../src')\n",
    "\n",
    "import torch\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "from biomassters.models.registry import build_model\n",
    "from biomassters.data.dataset import BioMasstersDataset\n",
    "from biomassters.data.transforms import get_val_transforms\n",
    "from biomassters.training.lit_module import BioMasstersLitModule\n",
    "from biomassters.utils.config import load_config, merge_configs, config_to_dict\n",
    "from biomassters.utils.visualization import plot_sample, make_rgb_composite\n",
    "\n",
    "# ── Configuration ─────────────────────────────────────────────────────────────\n",
    "CONFIG_PATH = '../configs/utae.yaml'\n",
    "CHECKPOINT  = '../results/utae/checkpoints/last.ckpt'  # update path as needed\n",
    "DATA_ROOT   = Path('../data/biomassters')\n",
    "\n",
    "DEVICE = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Using device: {DEVICE}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load model ────────────────────────────────────────────────────────────────\n",
    "base_cfg  = load_config('../configs/base.yaml')\n",
    "model_cfg = load_config(CONFIG_PATH)\n",
    "cfg       = merge_configs(base_cfg, model_cfg)\n",
    "\n",
    "model_name = cfg.model.name\n",
    "model = build_model(model_name, cfg)\n",
    "\n",
    "checkpoint_path = Path(CHECKPOINT)\n",
    "if checkpoint_path.exists():\n",
    "    lit = BioMasstersLitModule.load_from_checkpoint(\n",
    "        str(checkpoint_path),\n",
    "        model=model,\n",
    "        loss_name=cfg.loss.name,\n",
    "        optimizer_cfg=config_to_dict(cfg.optimizer),\n",
    "        scheduler_cfg=config_to_dict(cfg.scheduler),\n",
    "        log_images=False,\n",
    "    )\n",
    "    lit.eval().to(DEVICE)\n",
    "    print(f'Loaded {model_name} checkpoint from {checkpoint_path}')\n",
    "    print(f'Parameters: {model.count_parameters():,}')\n",
    "else:\n",
    "    print(f'Checkpoint not found: {checkpoint_path}')\n",
    "    print('Training model from scratch for demo...')\n",
    "    lit = BioMasstersLitModule(\n",
    "        model=model,\n",
    "        loss_name='masked_rmse',\n",
    "        optimizer_cfg=config_to_dict(cfg.optimizer),\n",
    "        scheduler_cfg=config_to_dict(cfg.scheduler),\n",
    "    ).to(DEVICE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load a sample chip ────────────────────────────────────────────────────────\n",
    "modalities = list(cfg.data.modalities)\n",
    "ds = BioMasstersDataset(\n",
    "    root_dir=DATA_ROOT,\n",
    "    split='train',\n",
    "    modalities=modalities,\n",
    "    transform=get_val_transforms(modalities=modalities),\n",
    ")\n",
    "\n",
    "CHIP_IDX = 7  # Try different indices\n",
    "sample = ds[CHIP_IDX]\n",
    "print(f\"Chip ID : {sample['chip_id']}\")\n",
    "print(f\"Image   : {sample['image'].shape}\")\n",
    "print(f\"Target  : {sample['target'].shape}\")\n",
    "\n",
    "# Run inference\n",
    "with torch.no_grad():\n",
    "    x = sample['image'].unsqueeze(0).to(DEVICE)  # (1, T, C, H, W)\n",
    "    pred = lit(x).squeeze(0).cpu()               # (1, H, W)\n",
    "    pred = pred.clamp(min=0.0)                   # AGB >= 0\n",
    "\n",
    "target = sample['target'].numpy()\n",
    "pred_np = pred.numpy()\n",
    "print(f'\\nPrediction range: [{pred_np.min():.1f}, {pred_np.max():.1f}] Mg/ha')\n",
    "print(f'Target range    : [{target.min():.1f}, {target.max():.1f}] Mg/ha')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Visualise ─────────────────────────────────────────────────────────────────\n",
    "# Get raw (un-normalised) image for display — reload without transforms\n",
    "ds_raw = BioMasstersDataset(\n",
    "    root_dir=DATA_ROOT, split='train', modalities=modalities\n",
    ")\n",
    "raw_sample = ds_raw[CHIP_IDX]\n",
    "\n",
    "plot_sample(\n",
    "    image=raw_sample['image'].numpy(),\n",
    "    target=target,\n",
    "    prediction=pred_np,\n",
    "    month=6,  # July\n",
    "    title=f\"Chip: {sample['chip_id']} — {model_name.upper()}\",\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Error map ─────────────────────────────────────────────────────────────────\n",
    "mask   = target[0] > 0\n",
    "error  = pred_np[0] - target[0]\n",
    "error_masked = np.where(mask, error, np.nan)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "\n",
    "vmax = max(target[0][mask].max(), pred_np[0][mask].max())\n",
    "axes[0].imshow(target[0], cmap='YlOrBr', vmin=0, vmax=vmax)\n",
    "axes[0].set_title('Ground Truth (Mg/ha)', fontweight='bold')\n",
    "axes[0].axis('off')\n",
    "\n",
    "axes[1].imshow(pred_np[0], cmap='YlOrBr', vmin=0, vmax=vmax)\n",
    "axes[1].set_title(f'{model_name.upper()} Prediction (Mg/ha)', fontweight='bold')\n",
    "axes[1].axis('off')\n",
    "\n",
    "err_abs = np.abs(error_masked).max()\n",
    "im = axes[2].imshow(error_masked, cmap='RdBu_r', vmin=-err_abs, vmax=err_abs)\n",
    "axes[2].set_title('Error (Pred − Target)', fontweight='bold')\n",
    "axes[2].axis('off')\n",
    "plt.colorbar(im, ax=axes[2], fraction=0.046, pad=0.04)\n",
    "\n",
    "plt.suptitle(f\"Chip: {sample['chip_id']}\", fontsize=13, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# RMSE for this chip\n",
    "valid_err = error_masked[mask]\n",
    "chip_rmse = np.sqrt((valid_err ** 2).mean())\n",
    "print(f'Chip RMSE: {chip_rmse:.2f} Mg/ha')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Export prediction as GeoTIFF ─────────────────────────────────────────────\n",
    "from biomassters.utils.io import save_prediction\n",
    "\n",
    "out_path = save_prediction(\n",
    "    pred=pred_np[0],\n",
    "    chip_id=sample['chip_id'],\n",
    "    output_dir='../predictions/demo/',\n",
    ")\n",
    "print(f'Saved prediction → {out_path}')"
   ]
  }
 ],
