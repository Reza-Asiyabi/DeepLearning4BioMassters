   "source": [
    "# 02 · Model Comparison — BioMassters Benchmark\n",
    "\n",
    "Load and compare evaluation results for all 5 trained architectures.\n",
    "\n",
    "**Requirements**: Run `make evaluate-all` and `make compare` first."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, json\n",
    "sys.path.insert(0, '../src')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from pathlib import Path\n",
    "\n",
    "RESULTS_DIR = Path('../results')\n",
    "MODELS = ['unet', 'unet3d', 'swin_unet', 'utae', 'tempfusionnet']\n",
    "MODEL_NAMES = {\n",
    "    'unet': 'U-Net',\n",
    "    'unet3d': '3D U-Net',\n",
    "    'swin_unet': 'Swin U-Net',\n",
    "    'utae': 'U-TAE',\n",
    "    'tempfusionnet': 'TempFusionNet (ours)',\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load results ─────────────────────────────────────────────────────────────\n",
    "results = {}\n",
    "for model in MODELS:\n",
    "    for fname in ['metrics_val.json', 'metrics.json']:\n",
    "        p = RESULTS_DIR / model / fname\n",
    "        if p.exists():\n",
    "            with open(p) as f:\n",
    "                results[model] = json.load(f)\n",
    "            break\n",
    "\n",
    "if not results:\n",
    "    print('No results found. Train models first: make train-all && make evaluate-all')\n",
    "else:\n",
    "    print(f'Loaded results for: {list(results.keys())}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Metrics table ─────────────────────────────────────────────────────────────\n",
    "def get_metric(data, key, split='val'):\n",
    "    for k in [f'{split}/{key}', key, f'test/{key}']:\n",
    "        if k in data:\n",
    "            return float(data[k])\n",
    "    return float('nan')\n",
    "\n",
    "rows = []\n",
    "for model, data in results.items():\n",
    "    rows.append({\n",
    "        'Model': MODEL_NAMES.get(model, model),\n",
    "        'RMSE': get_metric(data, 'rmse'),\n",
    "        'MAE': get_metric(data, 'mae'),\n",
    "        'R²': get_metric(data, 'r2'),\n",
    "        'Rel.RMSE (%)': get_metric(data, 'rel_rmse'),\n",
    "        '#Params': data.get('n_params', float('nan')),\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(rows).set_index('Model')\n",
    "df['#Params'] = df['#Params'].apply(lambda x: f'{x/1e6:.1f}M' if x == x else '-')\n",
    "display(df.sort_values('RMSE'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Bar chart comparison ──────────────────────────────────────────────────────\n",
    "from biomassters.utils.visualization import plot_metrics_comparison\n",
    "\n",
    "plot_metrics_comparison(\n",
    "    results_dict={\n",
    "        MODEL_NAMES.get(m, m): data for m, data in results.items()\n",
    "    },\n",
    "    metrics=['rmse', 'mae', 'r2'],\n",
    "    save_path='../assets/comparison_bar.png',\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Prediction scatter plots ─────────────────────────────────────────────────\n",
    "# Load predictions and targets for scatter plots\n",
    "# (Requires running scripts/predict.py for each model first)\n",
    "\n",
    "PRED_DIR = Path('../predictions')\n",
    "DATA_ROOT = Path('../data/biomassters')\n",
    "\n",
    "from biomassters.data.dataset import BioMasstersDataset\n",
    "ds = BioMasstersDataset(root_dir=DATA_ROOT, split='train')\n",
    "\n",
    "print('Run `scripts/predict.py` for each model to generate scatter plots.')\n",
    "print('Then reload this cell with prediction files in PRED_DIR.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Error map comparison (same chip across all models) ───────────────────────\n",
    "# Placeholder — populate after predictions are generated\n",
    "\n",
    "fig, axes = plt.subplots(2, len(results) + 1, figsize=(4 * (len(results) + 1), 8))\n",
    "\n",
    "print('Error maps will appear here after predictions are generated.')\n",
    "print('Each column: Ground Truth | U-Net | 3D U-Net | Swin | U-TAE | TempFusionNet')"
   ]
  }
